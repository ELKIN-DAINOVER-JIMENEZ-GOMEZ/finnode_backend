# ============================================================================
# Archivo de Variables de Entorno para FinNode - Ejemplo
# ============================================================================
# Copia este archivo a .env y llena los valores reales antes de ejecutar
# docker-compose:
#   cp .env.example .env

# OpenAI API Key para detección de fraude en Payment Orchestrator
# Obtén tu clave en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-actual-api-key-here

# Otras variables opcionales (si no se especifican, se usan los valores por defecto)
# JWT_ISSUER_URI=http://auth-service:8081
# JWT_JWK_SET_URI=http://auth-service:8081/.well-known/jwks.json
# FRAUD_RISK_THRESHOLD=0.75

